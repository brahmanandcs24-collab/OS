#include <stdio.h>

struct process
{
    int p_id;
    int atime;
    int btime;
    int ctime;
    int wtime;
    int tat;
};

int main()
{
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct process p[n], temp;

    for(int i = 0; i < n; i++)
    {
        printf("Enter Process ID, Arrival Time, Burst Time: ");
        scanf("%d %d %d", &p[i].p_id, &p[i].atime, &p[i].btime);
    }

    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            if(p[i].atime > p[j].atime)
            {
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    int current_time = 0;

    for(int i = 0; i < n; i++)
    {

        if(current_time < p[i].atime)
        {
            current_time = p[i].atime;
        }

        current_time += p[i].btime;

        p[i].ctime = current_time;
        p[i].tat = p[i].ctime - p[i].atime;
        p[i].wtime = p[i].tat - p[i].btime;
    }

    float total_wtime = 0, total_tat = 0;

    printf("\nPID\tAT\tBT\tCT\tWT\tTAT\n");

    for(int i = 0; i < n; i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].p_id,
               p[i].atime,
               p[i].btime,
               p[i].ctime,
               p[i].wtime,
               p[i].tat);

        total_wtime += p[i].wtime;
        total_tat += p[i].tat;
    }

    printf("\nAverage Waiting Time = %.2f", total_wtime / n);
    printf("\nAverage Turnaround Time = %.2f\n", total_tat / n);

    return 0;
}
