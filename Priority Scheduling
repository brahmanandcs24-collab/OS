#include<stdio.h>

struct process
{
    int p_id;
    int atime;
    int btime;
    int ctime;
    int wtime;
    int tat;
    int pri;
    int remaining;
    int completed;
};

int main()
{
    int n, i, ch;
    float avg_wtime, avg_tat;

    printf("Enter the number of processes");
    scanf("%d", &n);

    struct process p[n];

    for(i = 0; i < n; i++)
    {
        printf("Enter process id, priority, arrival time and burst time:");
        scanf("%d %d %d %d",
              &p[i].p_id,
              &p[i].pri,
              &p[i].atime,
              &p[i].btime);

        p[i].remaining = p[i].btime;
        p[i].completed = 0;
    }

    printf("\n1. Non - Preemptive \n2. Preemptive\n Enter the choice");
    scanf("%d", &ch);

    int current_time = 0;
    int completed = 0;

    switch(ch)
    {
        case 1:
        {
            while(completed < n)
            {
                int minP = 99999;
                int idx = -1;

                for(i = 0; i < n; i++)
                {
                    if(p[i].atime <= current_time &&
                       p[i].completed == 0)
                    {
                        if(p[i].pri < minP)
                        {
                            minP = p[i].pri;
                            idx = i;
                        }
                    }
                }

                if(idx != -1)
                {
                    current_time += p[idx].btime;

                    p[idx].ctime = current_time;
                    p[idx].tat = p[idx].ctime - p[idx].atime;
                    p[idx].wtime = p[idx].tat - p[idx].btime;

                    p[idx].completed = 1;
                    completed++;
                }
                else
                {
                    current_time++;
                }
            }
            break;
        }

        case 2:
        {
            while(completed < n)
            {
                int minP = 99999;
                int idx = -1;

                for(i = 0; i < n; i++)
                {
                    if(p[i].atime <= current_time &&
                       p[i].remaining > 0)
                    {
                        if(p[i].pri < minP)
                        {
                            minP = p[i].pri;
                            idx = i;
                        }
                    }
                }

                if(idx != -1)
                {
                    p[idx].remaining--;
                    current_time++;

                    if(p[idx].remaining == 0)
                    {
                        p[idx].ctime = current_time;
                        p[idx].tat =
                            p[idx].ctime - p[idx].atime;
                        p[idx].wtime =
                            p[idx].tat - p[idx].btime;

                        completed++;
                    }
                }
                else
                {
                    current_time++;
                }
            }
            break;
        }

        default:
            printf("Invalid choice!");
            return 0;
    }

    float sum_wtime = 0;
    float sum_tat = 0;

    for(i = 0; i < n; i++)
    {
        sum_wtime += p[i].wtime;
        sum_tat += p[i].tat;
    }

    avg_wtime = sum_wtime / n;
    avg_tat = sum_tat / n;

    printf("Process ID | Priority | Arrival Time | Burst Time | Completion Time | Waiting Time | Turnaround Time\n");

    for(i = 0; i < n; i++)
    {
        printf("%d | %d | %d | %d | %d | %d | %d\n",
               p[i].p_id,
               p[i].pri,
               p[i].atime,
               p[i].btime,
               p[i].ctime,
               p[i].wtime,
               p[i].tat);
    }

    printf("\nAverage Waiting Time: %f \nAverage Turnaround Time: %f",
           avg_wtime,
           avg_tat);

    return 0;
}
