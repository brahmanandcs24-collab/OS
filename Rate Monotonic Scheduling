#include <stdio.h>

struct Process
{
    int id;
    int period;
    int burst;
    int remaining;
    int nextArrival;
};

int main()
{
    int n, time, i, highest;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n];

    for(i = 0; i < n; i++)
    {
        printf("\nProcess P%d\n", i + 1);

        p[i].id = i + 1;

        printf("Enter Burst Time: ");
        scanf("%d", &p[i].burst);

        printf("Enter Period: ");
        scanf("%d", &p[i].period);

        p[i].remaining = 0;
        p[i].nextArrival = 0;
    }

    int limit;
    printf("\nEnter simulation time: ");
    scanf("%d", &limit);

    printf("\nTime\tRunning Process\n");

    for(time = 0; time < limit; time++)
    {
        for(i = 0; i < n; i++)
        {
            if(time == p[i].nextArrival)
            {
                p[i].remaining = p[i].burst;
                p[i].nextArrival += p[i].period;
            }
        }

        highest = -1;

        for(i = 0; i < n; i++)
        {
            if(p[i].remaining > 0)
            {
                if(highest == -1 || p[i].period < p[highest].period)
                {
                    highest = i;
                }
            }
        }

        if(highest != -1)
        {
            printf("%d\tP%d\n", time, p[highest].id);
            p[highest].remaining--;
        }
        else
        {
            printf("%d\tIdle\n", time);
        }
    }

    return 0;
}
