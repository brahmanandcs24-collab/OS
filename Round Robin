#include <stdio.h>

struct process
{
    int p_id;
    int atime;
    int btime;
    int remaining;
    int ctime;
    int wtime;
    int tat;
};

int main()
{
    int n, qt;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct process p[n];

    for(int i = 0; i < n; i++)
    {
        printf("Enter Process ID, Arrival Time, Burst Time: ");
        scanf("%d %d %d", &p[i].p_id, &p[i].atime, &p[i].btime);
        p[i].remaining = p[i].btime;
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &qt);

    int time = 0, completed = 0;
    int queue[100], front = 0, rear = 0;
    int visited[n];

    for(int i = 0; i < n; i++)
        visited[i] = 0;

    queue[rear++] = 0;
    visited[0] = 1;

    while(completed < n)
    {
        int i = queue[front++];

        if(p[i].remaining > qt)
        {
            time += qt;
            p[i].remaining -= qt;
        }
        else
        {
            time += p[i].remaining;
            p[i].remaining = 0;

            p[i].ctime = time;
            p[i].tat = p[i].ctime - p[i].atime;
            p[i].wtime = p[i].tat - p[i].btime;

            completed++;
        }

        for(int j = 0; j < n; j++)
        {
            if(p[j].atime <= time && visited[j] == 0)
            {
                queue[rear++] = j;
                visited[j] = 1;
            }
        }

        if(p[i].remaining > 0)
        {
            queue[rear++] = i;
        }

        if(front == rear)
        {
            for(int j = 0; j < n; j++)
            {
                if(p[j].remaining > 0)
                {
                    queue[rear++] = j;
                    visited[j] = 1;
                    time = p[j].atime;
                    break;
                }
            }
        }
    }

    float total_wt = 0, total_tat = 0;

    printf("\nPID\tAT\tBT\tCT\tWT\tTAT\n");
    for(int i = 0; i < n; i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].p_id, p[i].atime, p[i].btime,
               p[i].ctime, p[i].wtime, p[i].tat);

        total_wt += p[i].wtime;
        total_tat += p[i].tat;
    }

    printf("\nAverage Waiting Time = %.2f", total_wt / n);
    printf("\nAverage Turnaround Time = %.2f\n", total_tat / n);

    return 0;
}
